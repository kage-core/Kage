# Kage — gitignore
.DS_Store
.agent_memory/*
!.agent_memory/
!.agent_memory/packets/
!.agent_memory/packets/*.json
# Auto-generated repo-map packets are derived data (regenerated by `kage refresh`)
# and must not be tracked — they cause spurious merge conflicts. The repo-key infix
# (e.g. repo_map-kage-repo-overview-*) means the glob must allow any text before
# "repo-overview"/"repo-structure".
.agent_memory/packets/repo_map-*repo-overview-*.json
.agent_memory/packets/repo_map-*repo-structure-*.json
.claude/
.agents/
# but track the Codex plugin marketplace manifest (Codex reads .agents/plugins/)
!.agents/
!.agents/plugins/
!.agents/plugins/marketplace.json
.cursorrules
__pycache__/
*.pyc
node_modules/
dist/
mcp/viewer/graphs/*.json
docs/assets/viewer-demo-frames*/
docs/assets/*.mp4
docs/assets/*.mov
docs/assets/*.webm
docs/assets/*.typescript
*.mov
*.tgz
.openai-bench.env
# Private keys (e.g. MCP registry DNS-auth ed25519 key) — never commit
*.pem
kage-mcp-key.pem
