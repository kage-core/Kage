# Kage workspace deployment configuration. Copy to `.env` beside the compose file and fill in.
#
# EVERY VALUE HERE IS EMPTY ON PURPOSE. A shipped example with a working default password is how a
# self-hosted service ends up running with the example password. Nothing in this repository ever
# contains a real secret, and `.env` is gitignored.
#
# Required: KAGE_WORKSPACE_DATABASE_URL, POSTGRES_PASSWORD, KAGE_BACKUP_KEY.
# Everything else is optional and switches off the feature it configures when unset.

# --- database ---------------------------------------------------------------------------------
# The workspace service's connection string. There is deliberately no default: the service refuses to
# start rather than guess a database. Inside the compose network the host is `postgres`:
#   postgres://kage:YOUR_PASSWORD@postgres:5432/kage_workspace
KAGE_WORKSPACE_DATABASE_URL=

# Consumed by the postgres container on first initialisation.
POSTGRES_DB=kage_workspace
POSTGRES_USER=kage
POSTGRES_PASSWORD=

# --- service ----------------------------------------------------------------------------------
KAGE_WORKSPACE_PORT=8787
# The address the SERVICE binds INSIDE the container. Default 0.0.0.0 (every interface): Docker DNATs a
# published port to the container's bridge IP, so a service bound to loopback is unreachable through the
# published port even though the in-container healthcheck still passes. Leave this at 0.0.0.0 in a
# container; the exposure is narrowed at the PUBLISH boundary below, not by binding loopback here.
KAGE_WORKSPACE_HOST=0.0.0.0
# The address:port published on the HOST. The service speaks plain HTTP, so it is published on the host
# LOOPBACK by default — put a TLS terminator (your ingress, a reverse proxy) in front of it and have that
# terminator reach 127.0.0.1:PORT. Set KAGE_WORKSPACE_PUBLISH_ADDR=0.0.0.0 only if you deliberately want
# plain HTTP on every host interface.
KAGE_WORKSPACE_PUBLISH_ADDR=127.0.0.1
KAGE_WORKSPACE_PUBLISH_PORT=8787
# The schema version this image expects. The health probe fails a container whose database is behind it,
# so a half-migrated or wrongly-pointed pod never becomes ready. Bump with the image.
KAGE_WORKSPACE_EXPECTED_MIGRATION=12
# The health probe's target inside the container (it talks to the loopback the service also binds) and
# its timeout. Defaults suit the shipped compose; a k8s probe can override them.
KAGE_WORKSPACE_HEALTH_HOST=127.0.0.1
KAGE_WORKSPACE_HEALTH_TIMEOUT_MS=4000
# Optional: where single-tenant exports are written. Unset, a per-process 0700 temp directory is used.
KAGE_WORKSPACE_EXPORT_DIR=

# --- backups ----------------------------------------------------------------------------------
# Base64-encoded 32 bytes: `openssl rand -base64 32`. backup.sh refuses to run without it — a backup is
# never written unencrypted. Store it somewhere OTHER than the machine holding the backups; a key kept
# beside the file it protects protects nothing.
KAGE_BACKUP_KEY=
# Optional: read the key from a mounted secret file instead of the environment.
KAGE_BACKUP_KEY_FILE=
# Optional: the SHA-256 recorded in your backup catalogue. restore.sh refuses a file that does not match.
KAGE_BACKUP_SHA256=

# --- billing (optional; unset = billing routes stay off) ---------------------------------------
# Set BOTH the secret key and the webhook secret to turn billing on; either one unset leaves the Stripe
# webhook route returning 404 (an unconfigured integration is simply not there).
KAGE_STRIPE_SECRET_KEY=
KAGE_STRIPE_WEBHOOK_SECRET=
# plan -> Stripe price id (per-deployment data, not committed). A plan with no price cannot be checked out.
KAGE_STRIPE_PRICE_TEAM=
KAGE_STRIPE_PRICE_BUSINESS=
KAGE_STRIPE_PRICE_ENTERPRISE=
# Optional: where Stripe returns the browser after checkout.
KAGE_STRIPE_SUCCESS_URL=
KAGE_STRIPE_CANCEL_URL=
# Optional: override the Stripe API base (e.g. a mock in staging). Defaults to https://api.stripe.com.
KAGE_STRIPE_API_BASE_URL=

# --- GitHub App (optional; unset = the integration stays off) ----------------------------------
# Set app id, private key, AND webhook secret to turn the integration on; any one unset leaves the
# GitHub webhook route returning 404. The variable names here are EXACTLY what the service reads.
KAGE_GITHUB_APP_ID=
# PKCS#8 PEM. A deployment secret may carry escaped \n; the service restores real newlines.
KAGE_GITHUB_PRIVATE_KEY=
KAGE_GITHUB_WEBHOOK_SECRET=
# Optional: override the GitHub API base (e.g. GitHub Enterprise). Defaults to https://api.github.com.
KAGE_GITHUB_API_BASE_URL=

# --- enterprise SSO (optional; enterprise entitlement required) --------------------------------
# The OIDC client secret is referenced BY NAME from the database and resolved from this environment at
# use time, so a database dump never carries an OAuth credential. Set the variable your provider row
# names in `client_secret_ref`.
KAGE_OIDC_CLIENT_SECRET=
