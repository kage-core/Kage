{
  "name": "@kage-core/kage-graph-mcp",
  "version": "3.3.0",
  "description": "Agent memory on Google's Open Knowledge Format (OKF). Kage maintains your coding agents' OKF memory bundle in git and verifies every concept against your code, deterministically. The verification and freshness layer OKF leaves out. MCP server, no account, no API key.",
  "main": "dist/index.js",
  "files": [
    "dist/**/*.js",
    "!dist/**/*.test.js",
    "!dist/release.js",
    "viewer/**/*",
    "!viewer/graphs/*.json",
    "README.md"
  ],
  "bin": {
    "kage-graph-mcp": "dist/index.js",
    "kage": "dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node index.ts",
    "test": "npm run build && node --test 'dist/**/*.test.js' && npm run test:dogfood",
    "test:vnext": "npm run build && node --test 'dist/vnext/**/*.test.js'",
    "test:phase-c": "npm run build && node --test dist/vnext/phase-c-gate.test.js dist/vnext/api/events.test.js",
    "test:dogfood": "node --test ../evals/agent-trajectory/replay.test.mjs",
    "bench:injection": "node ../benchmarks/injection-relevance-kage.mjs",
    "bench:capture": "node ../benchmarks/capture-quality-kage.mjs",
    "bench:reuse": "node ../benchmarks/reuse-value-kage.mjs",
    "bench:compression": "node ../benchmarks/compression-realbody-kage.mjs"
  },
  "keywords": [
    "mcp",
    "kage",
    "memory",
    "knowledge-graph",
    "codex",
    "claude",
    "ai-agents",
    "code-graph",
    "okf",
    "agent-memory"
  ],
  "license": "GPL-3.0-only",
  "author": "Kage Core",
  "homepage": "https://kage-core.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kage-core/Kage.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/kage-core/Kage/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "jose": "^6.2.3",
    "pg": "^8.22.0",
    "stripe": "^22.3.2",
    "three": "^0.184.0",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^5.0.0",
    "web-tree-sitter": "^0.24.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "embedded-postgres": "^18.4.0-beta.17"
  },
  "engines": {
    "node": ">=18"
  },
  "mcpName": "com.kage-core/kage"
}
